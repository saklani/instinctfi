---
import "@/styles/global.css"
import { Font } from "astro:assets"

const SITE_URL = "https://www.instinctfi.com"
const SITE_NAME = "Instinct"
const TITLE = "Instinct | Your cheatcode to Internet Capital Markets"
const DESCRIPTION =
  "Curated tokenised stock vaults on Solana, track the smartest money through Instinct equity vaults, onchain, join the Instinct private alpha"
const KEYWORDS = [
  "Instinct",
  "Internet Capital Markets",
  "ICM",
  "tokenised stocks",
  "tokenized stocks",
  "stock vaults",
  "onchain equities",
  "Solana",
  "DeFi",
  "smartest money",
].join(", ")

const canonical = new URL(Astro.url.pathname, SITE_URL).toString()
const ogImage = new URL("/og-image.png", SITE_URL).toString()
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#024cc7" />
    <meta name="color-scheme" content="light" />

    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-bricolage-grotesque" preload />

    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="generator" content="Astro" />
    <meta name="keywords" content={KEYWORDS} />
    <meta name="author" content="Instinct" />
    <meta name="creator" content="Instinct" />
    <meta name="publisher" content="Instinct" />
    <meta name="category" content="finance" />
    <meta name="format-detection" content="telephone=no, address=no, email=no" />

    <meta name="robots" content="index, follow" />
    <meta
      name="googlebot"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={TITLE} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={TITLE} />
  </head>
  <body class="font-sans antialiased">
    <div class="dots-bg" aria-hidden="true"></div>
    <slot />
  </body>
</html>
