---
const PARTNERS = [
  { name: "Solana",   src: "/partners/solana.svg" },
  { name: "Jupiter",  src: "/partners/jupiter.svg" },
  { name: "Symmetry", src: "/partners/symmetry.svg" },
  { name: "Pyth",     src: "/partners/pyth.svg" },
  { name: "xStocks",  src: "/partners/xstocks.svg" },
  { name: "Ondo",     src: "/partners/ondo.svg" },
]

const loop = [...PARTNERS, ...PARTNERS, ...PARTNERS, ...PARTNERS]
---

<div class="border-y w-full h-20 flex items-center overflow-hidden">
  <div class="partners-track flex items-center">
    {loop.map((p, i) => (
      <div
        class="h-4 shrink-0 flex items-center mr-20"
        aria-hidden={i >= PARTNERS.length ? "true" : undefined}
      >
        <img src={p.src} alt={p.name} class="h-full w-auto" />
      </div>
    ))}
  </div>
</div>

<style>
  .partners-track {
    width: max-content;
    animation: partners-scroll 40s linear infinite;
    will-change: transform;
  }
  .partners-track:hover {
    animation-play-state: paused;
  }
  @keyframes partners-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-25%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .partners-track { animation: none; }
  }
</style>
