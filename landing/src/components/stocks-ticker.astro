---
const STOCKS = [
  { ticker: "NVDAx", mint: "Xsc9qvGR1efVDFGLrVsmkzv3qi45LTBjeUKSPmx9qEh" },
  { ticker: "GOOGLx", mint: "XsCPL9dNWBMvFtTmwcCA5v3xWPSMEBCszbQdiLLq6aN" },
  { ticker: "AMZNx", mint: "Xs3eBt7uRfJX8QUs4suhyU8p2M6DoUDrJyWBa8LLZsg" },
  { ticker: "AAPLx", mint: "XsbEhLAtcf6HdfpFZ5xEMdqW8nfAvcsP5bdudRLJzJp" },
  { ticker: "METAx", mint: "Xsa62P5mvPszXL1krVUnU5ar38bBSVcWAB6fmPCo5Zu" },
  { ticker: "PLTRx", mint: "XsoBhf2ufR8fTyNSjqfU71DYGaE6Z3SUGAidpzriAA4" },
  { ticker: "MSFTx", mint: "XspzcW1PRtgf6Wj92HCiZdjzKCyFekVD8P5Ueh3dRMX" },
  { ticker: "TSLAx", mint: "XsDoVfqeBukxuZHWhdvWHBhgEHjGNst4MLodqsJHzoB" },
  { ticker: "HOODx", mint: "XsvNBAYkrDRNhA7wPHQfX3ZUXZyZLdnCQDfHZ56bzpg" },
  { ticker: "COINx", mint: "Xs7ZdzSHLU9ftNJsii5fCeJhoRWSC32SQGzGQtePxNu" },
  { ticker: "CRCLx", mint: "XsueG8BtpquVJX9LVLLEGuViXUungE6WmK5YZ3p3bd1" },
  { ticker: "MSTRx", mint: "XsP7xzNPvEHS1m6qfanPUGjNmdnmsLKEoNAnHjdxxyZ" },
  { ticker: "STRCx", mint: "Xs78JED6PFZxWc2wCEPspZW9kL3Se5J7L5TChKgsidH" },
  { ticker: "LLYx",  mint: "Xsnuv4omNoHozR6EEW5mXkw8Nrny5rB3jVfLqi6gKMH" },
  { ticker: "NVOx",  mint: "XsfAzPzYrYjd4Dpa9BU3cusBsvWfVB9gBcyGC87S57n" },
  { ticker: "TMOx",  mint: "Xs8drBWy3Sd5QY3aifG9kt9KFs2K3PGZmx7jWrsrk57" },
  { ticker: "DHRx",  mint: "Xseo8tgCZfkHxWS9xbFYeKFyMSbWEvZGFV1Gh53GtCV" },
  { ticker: "GLXYx", mint: "Xs3c2aZenyRQwXjki5MDxJEJ2km27ef2rWQMFWx7QKJ" },
] as const

interface JupPrice {
  usdPrice: number
  /** Raw percent, e.g. 1.3 = +1.30% */
  priceChange24h: number
}

async function fetchPrices(): Promise<Record<string, JupPrice>> {
  const apiKey = import.meta.env.JUPITER_API_KEY ?? process.env.JUPITER_API_KEY
  const ids = STOCKS.map((s) => s.mint).join(",")
  const base = apiKey ? "https://api.jup.ag/price/v3" : "https://lite-api.jup.ag/price/v3"
  const url = `${base}?ids=${ids}&showExtraInfo=true`
  try {
    const res = await fetch(url, {
      headers: apiKey ? { "x-api-key": apiKey } : undefined,
    })
    if (!res.ok) return {}
    const json = (await res.json()) as Record<string, { usdPrice?: number; priceChange24h?: number }>
    const out: Record<string, JupPrice> = {}
    for (const s of STOCKS) {
      const e = json[s.mint]
      if (!e) continue
      out[s.mint] = {
        usdPrice: Number(e.usdPrice ?? 0),
        priceChange24h: Number(e.priceChange24h ?? 0),
      }
    }
    return out
  } catch {
    return {}
  }
}

const prices = await fetchPrices()

const items = STOCKS.map((s) => {
  const p = prices[s.mint]
  return {
    ticker: s.ticker,
    image: `https://ik.imagekit.io/8dj2mc8pj/${s.ticker}.png`,
    price: p?.usdPrice,
    change: p?.priceChange24h,
  }
})

const loop = [...items, ...items]
---

<section
  class="relative w-full overflow-hidden border-y border-black/5 bg-white/60 py-5 backdrop-blur-sm"
  aria-label="Live xStock prices"
>
  <div
    class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-background to-transparent"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-background to-transparent"
  >
  </div>

  <div class="ticker-track flex items-center gap-10">
    {loop.map((item, i) => (
      <div
        class="flex shrink-0 items-center gap-3 whitespace-nowrap"
        aria-hidden={i >= items.length ? "true" : undefined}
      >
        <img
          src={item.image}
          alt={item.ticker}
          width={28}
          height={28}
          loading="lazy"
          decoding="async"
          class="size-7 rounded-full ring-1 ring-black/5"
        />
        <span class="text-sm font-medium text-foreground tracking-tight">
          {item.ticker}
        </span>
        {item.price !== undefined && item.price > 0 && (
          <span class="text-sm tabular-nums text-muted-foreground">
            ${item.price.toFixed(2)}
          </span>
        )}
        {item.change !== undefined && (
          <span
            class={`text-xs font-medium tabular-nums ${
              item.change >= 0 ? "text-bar-green" : "text-bar-red"
            }`}
          >
            {item.change >= 0 ? "▲" : "▼"} {Math.abs(item.change).toFixed(2)}%
          </span>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .ticker-track {
    width: max-content;
    animation: ticker-scroll 80s linear infinite;
    will-change: transform;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
