---
import Column from "./ui/column.astro"
import Section from "./ui/section.astro"

const PILLARS = [
  {
    icon: "coins" as const,
    title: "One transaction",
    body: "Buy a whole Instinct in a single transaction, no leg juggling, no per-trade slippage",
  },
  {
    icon: "scale" as const,
    title: "Self-rebalancing",
    body: "Weights reroll as the Instinct evolves, hands-off, no stressful rebalance day",
  },
  {
    icon: "building-2" as const,
    title: "Real underlying Assets",
    body: "Symmetry-wrapped xStocks track the equity, not a synthetic perp",
  },
  {
    icon: "blocks" as const,
    title: "Composable onchain",
    body: "Vault tokens are SPL, collateralize, LP, or plug into Solana DeFi",
  },
  {
    icon: "eye" as const,
    title: "Fully transparent",
    body: "Every vault is visible onchain, verify holdings, flows and rebalances anytime",
  },
  {
    icon: "zap" as const,
    title: "Built on Solana",
    body: "Fast execution, global access, internet-native rails, settled in seconds",
  },
]
---

<Section class="border-b">
  <Column class="py-16 lg:py-36 gap-4">
    <h2 class="text-center w-full mb-6">Built for people who pay attention to the internet</h2>
    <ul class="grid gap-4 md:grid-cols-2 md:gap-6 lg:grid-cols-3">
      {PILLARS.map((p) => (
        <li class="group flex flex-col gap-8 rounded-2xl border border-black/5 bg-white p-6 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-primary/20 hover:shadow-[0_12px_32px_-16px_rgba(2,76,199,0.25)]">
          <span class="inline-flex size-11 items-center justify-center rounded-xl bg-foreground/[0.04] text-foreground transition-colors duration-300 group-hover:bg-primary/10 group-hover:text-primary">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              {p.icon === "coins" && (
                <>
                  <circle cx="8" cy="8" r="6" />
                  <path d="M18.09 10.37A6 6 0 1 1 10.34 18" />
                  <path d="M7 6h1v4" />
                  <path d="m16.71 13.88.7.71-2.82 2.82" />
                </>
              )}
              {p.icon === "scale" && (
                <>
                  <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
                  <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
                  <path d="M7 21h10" />
                  <path d="M12 3v18" />
                  <path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2" />
                </>
              )}
              {p.icon === "building-2" && (
                <>
                  <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" />
                  <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" />
                  <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" />
                  <path d="M10 6h4" />
                  <path d="M10 10h4" />
                  <path d="M10 14h4" />
                  <path d="M10 18h4" />
                </>
              )}
              {p.icon === "blocks" && (
                <>
                  <rect width="7" height="7" x="14" y="3" rx="1" />
                  <path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3" />
                </>
              )}
              {p.icon === "eye" && (
                <>
                  <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" />
                  <circle cx="12" cy="12" r="3" />
                </>
              )}
              {p.icon === "zap" && (
                <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" />
              )}
            </svg>
          </span>
          <div class="flex flex-col gap-2">
            <h3 class="text-foreground">{p.title}</h3>
            <p>{p.body}</p>
          </div>
        </li>
      ))}
    </ul>
    </Column>
</Section>
