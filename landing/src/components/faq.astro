---
const ITEMS = [
  {
    q: "What exactly am I buying?",
    a: "You're buying tokenized exposure to a curated vault of stocks, ETFs and tokens tied to a specific trend or narrative.",
  },
  {
    q: "Why not just buy ETFs?",
    a: "ETFs are broad and slow-moving. Instinct vaults are built around specific internet-native trends and cultural momentum.",
  },
  {
    q: "Is this trading or investing?",
    a: "Depends how early you are.",
  },
  {
    q: "Do I control my assets?",
    a: "Yes. Assets remain self-custodial in your wallet at all times.",
  },
  {
    q: "Why Solana?",
    a: "Fast execution, low fees and global accessibility make Solana the best place for internet capital market bets.",
  },
]
---

<section
  id="faq"
  class="mx-auto flex w-full max-w-3xl flex-col gap-12 px-6 py-24"
>
  <header class="flex flex-col items-center gap-3 text-center">
    <span class="eyebrow">FAQs</span>
    <h2>Questions, mostly the obvious ones.</h2>
  </header>

  <ul class="flex flex-col gap-3">
    {ITEMS.map((item) => (
      <li>
        <details class="group rounded-2xl border border-black/5 bg-white">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5">
            <h3 class="text-foreground">{item.q}</h3>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <div class="border-t border-black/5 px-6 py-5">
            <p>{item.a}</p>
          </div>
        </details>
      </li>
    ))}
  </ul>
</section>

<style>
  summary {
    list-style: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
</style>
